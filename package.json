{
  "name": "playgift-mobile",
  "version": "1.0.0",
  "description": "PlayGift - AI-powered gift game creator. 60-second magic. Create Pixar-quality personalized games with Dodo the Alchemist. Magic egg hatching, couples games, UAE-first.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "build:web": "npx expo export -p web --output-dir web-build",
    "build:ios": "echo 'Deprecated: Use EAS Build instead - npm run eas:build:ios'",
    "build:android": "echo 'Deprecated: Use EAS Build instead - npm run eas:build:android'",
    "deploy:vercel": "npm run build:web && vercel --prod",
    "deploy:netlify": "npm run build:web && netlify deploy --prod --dir=web-build",
    "deploy:firebase": "npm run build:web && firebase deploy",
    "deploy:firebase-rules": "node scripts/deploy-firebase-rules.js",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:preview": "eas build --platform android --profile preview",
    "setup": "node scripts/setup-wizard.js",
    "validate-config": "node scripts/validate-config.js",
    "check-config": "node scripts/validate-config.js",
    "generate:dodo-marketing": "node scripts/generate-dodo-marketing-assets.js",
    "generate:valentine-assets": "node scripts/generate-dodo-marketing-assets.js --theme valentine",
    "generate:ramadan-assets": "node scripts/generate-dodo-marketing-assets.js --theme ramadan",
    "marketing:generate-all": "node scripts/generate-all-marketing-content.js",
    "marketing:valentine": "node scripts/generate-all-marketing-content.js valentine && node scripts/generate-dodo-marketing-assets.js --theme valentine",
    "marketing:ramadan": "node scripts/generate-all-marketing-content.js ramadan && node scripts/generate-dodo-marketing-assets.js --theme ramadan",
    "marketing:schedule": "node scripts/auto-schedule-posts.js",
    "marketing:auto": "node scripts/auto-generate-marketing.js",
    "viral:analyze": "node scripts/viral-content-analyzer.js",
    "viral:generate-teaser": "node scripts/viral-content-analyzer.js && node scripts/generate-viral-teaser.js",
    "viral:generate-with-egg": "node scripts/viral-content-analyzer.js && node scripts/generate-viral-teaser.js --include-egg",
    "rebrand:playgift": "node scripts/rebrand-to-playgift.js",
    "repo:cleanup": "node scripts/cleanup-repo.js",
    "repo:auto-cleanup": "node scripts/cleanup-repo.js --auto",
    "agents:brainstorm": "node scripts/agent-creative-session.js",
    "agents:test": "node scripts/agent-creative-session.js",
    "rebrand:playgift": "node scripts/rebrand-to-playgift.js",
    "repo:cleanup": "node scripts/cleanup-repo.js",
    "dashboard:build": "node scripts/build-control-dashboard.js"
  },
  "keywords": [
    "game",
    "engine",
    "ai",
    "mobile",
    "vr",
    "ar",
    "gamedev",
    "no-code"
  ],
  "author": "GameForge Team",
  "license": "MIT",
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.11",
    "@stripe/stripe-react-native": "^0.35.0",
    "aframe": "^1.5.0",
    "aframe-react": "^4.4.0",
    "axios": "^1.6.2",
    "babylonjs": "^6.33.1",
    "babylonjs-loaders": "^6.33.1",
    "date-fns": "^2.30.0",
    "expo": "~49.0.15",
    "expo-build-properties": "~1.0.10",
    "expo-gl": "~13.0.1",
    "expo-linear-gradient": "^15.0.8",
    "expo-status-bar": "~1.6.0",
    "firebase": "^10.7.1",
    "lottie-react-native": "6.0.1",
    "pixi.js": "^7.3.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.6",
    "react-native-firebase": "^5.6.0",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-paytabs": "^2.6.10",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-svg": "13.9.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "~0.19.6",
    "react-native-webview": "13.2.2",
    "react-query": "^3.39.3",
    "three": "^0.182.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.14",
    "@types/react-native": "~0.72.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-expo": "^7.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~49.0.0",
    "prettier": "^3.1.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": false
}
