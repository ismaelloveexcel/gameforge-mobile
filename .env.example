# GameForge - AI API Configuration
# The app supports both OpenAI and Grok APIs with automatic fallback

# =====================================================
# OPENAI API (Recommended - More reliable)
# =====================================================
# Get your API key from https://platform.openai.com/api-keys
# Supports gpt-4o-mini (cost-effective) and gpt-4o (higher quality)
OPENAI_API_KEY=your_openai_api_key_here

# For Expo/React Native (prefix with EXPO_PUBLIC_)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# =====================================================
# GROK API (Alternative - x.ai)
# =====================================================
# Get your API key from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# For Expo/React Native (prefix with EXPO_PUBLIC_)
EXPO_PUBLIC_GROK_API_KEY=your_grok_api_key_here

# =====================================================
# FIREBASE (Shared Content Database) - REQUIRED
# =====================================================
# Firebase powers the Unified Ecosystem content database
# Used by both GameForge Mobile and GameDevelopmentHub
#
# Setup Instructions:
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (or use existing)
# 3. Enable Firestore Database:
#    - Go to Firestore Database in the left menu
#    - Click "Create database"
#    - Start in production mode (we'll set rules later)
#    - Choose your region (asia-south1 for UAE)
# 4. Get your config:
#    - Go to Project Settings (gear icon) > General
#    - Scroll to "Your apps" section
#    - Click "Web" icon to create a web app
#    - Copy the firebaseConfig values below
#
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# =====================================================
# PAYMENT PROVIDERS (Choose ONE)
# =====================================================
# The app supports multiple payment providers with automatic fallback
# Configure at least one to enable real payments
# If none configured, app runs in DEMO MODE (free gifts only)

# ─────────────────────────────────────────────────────
# Option 1: PayTabs (RECOMMENDED for UAE)
# ─────────────────────────────────────────────────────
# PayTabs is the preferred payment provider for UAE market
# Supports: Cards, Apple Pay, STC Pay, Mada, etc.
#
# Setup Instructions:
# 1. Sign up at https://site.paytabs.com
# 2. Complete KYB verification
# 3. Get your credentials:
#    - Dashboard > Developers > API Keys
#    - Profile ID (required)
#    - Server Key (for backend/validation)
#    - Client Key (for mobile app)
# 4. Test Mode: Use test credentials first
#    - Test Card: 4111 1111 1111 1111
#    - CVV: 123, Any future expiry
#
EXPO_PUBLIC_PAYTABS_PROFILE_ID=your_profile_id
EXPO_PUBLIC_PAYTABS_SERVER_KEY=your_server_key
EXPO_PUBLIC_PAYTABS_CLIENT_KEY=your_client_key

# ─────────────────────────────────────────────────────
# Option 2: Stripe (Alternative/International)
# ─────────────────────────────────────────────────────
# Stripe works internationally but has limitations in UAE
# Use as fallback or for international markets
#
# Setup Instructions:
# 1. Sign up at https://stripe.com
# 2. Get your publishable key:
#    - Dashboard > Developers > API Keys
#    - Copy "Publishable key" (starts with pk_test_ or pk_live_)
# 3. Test Mode: Use test key first
#    - Test Card: 4242 4242 4242 4242
#    - CVV: Any 3 digits, Any future expiry
#
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =====================================================
# DEPLOYMENT & SECRETS MANAGEMENT
# =====================================================
# For production deployment:
# - Add all keys as secrets in your deployment platform
# - GitHub Actions: Repository Settings > Secrets
# - Vercel: Project Settings > Environment Variables
# - Cursor Cloud Agents: Dashboard > Secrets
#
# Security Best Practices:
# - NEVER commit actual keys to git
# - Use test/sandbox keys for development
# - Rotate keys periodically in production
# - Keep server keys secure (never expose in client)

# =====================================================
# NOTES
# =====================================================
# AI Generation:
# - OpenAI API is preferred (more reliable)
# - Grok is alternative (good for variety)
# - No API key? App uses high-quality fallback templates
#
# Firebase:
# - REQUIRED for Unified Ecosystem
# - Shared database between Mobile app and Agents
# - Stores: games, orders, gifts, analytics
#
# Payments:
# - PayTabs: Best for UAE (AED support, local methods)
# - Stripe: Good for international markets
# - None configured: Demo mode (free gifts only)
#
# Models Used:
# - OpenAI: gpt-4o-mini (cost-effective)
# - Grok: grok-beta (creative alternative)
