# GiftForge - AI API Configuration
# Get your API keys from the respective providers

# Grok AI (x.ai) - Primary AI provider
# Get your API key from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# OpenAI / ChatGPT - Alternative AI provider
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AI Provider Selection (optional)
# Options: 'grok' | 'openai' | 'auto'
# 'auto' will use OpenAI if available, fallback to Grok
AI_PROVIDER=auto
