# GameForge - AI API Configuration
# The app supports both OpenAI and Grok APIs with automatic fallback

# =====================================================
# OPENAI API (Recommended - More reliable)
# =====================================================
# Get your API key from https://platform.openai.com/api-keys
# Supports gpt-4o-mini (cost-effective) and gpt-4o (higher quality)
OPENAI_API_KEY=your_openai_api_key_here

# For Expo/React Native (prefix with EXPO_PUBLIC_)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# =====================================================
# GROK API (Alternative - x.ai)
# =====================================================
# Get your API key from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# For Expo/React Native (prefix with EXPO_PUBLIC_)
EXPO_PUBLIC_GROK_API_KEY=your_grok_api_key_here

# =====================================================
# FIREBASE (Shared Content Database)
# =====================================================
# Create a Firebase project at https://console.firebase.google.com
# Enable Firestore and get your config from Project Settings > General
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# =====================================================
# PAYMENT (UAE-Compatible)
# =====================================================
# PayTabs (Recommended for UAE) - https://site.paytabs.com
EXPO_PUBLIC_PAYTABS_PROFILE_ID=your_profile_id
EXPO_PUBLIC_PAYTABS_SERVER_KEY=your_server_key
EXPO_PUBLIC_PAYTABS_CLIENT_KEY=your_client_key

# OR Stripe - https://stripe.com
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =====================================================
# NOTES
# =====================================================
# - OpenAI API is preferred and will be used by default if both keys are provided
# - If no API key is provided, the app uses high-quality fallback content
# - For GitHub Actions/Secrets: Add OPENAI_API_KEY as a repository secret
# - Model used: gpt-4o-mini for OpenAI, grok-beta for Grok
# - Firebase is required for the content database and gift tracking
# - Payment integration (PayTabs/Stripe) is required for premium games
